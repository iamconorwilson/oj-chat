{
  "name": "oj-chat",
  "version": "2.4.0",
  "description": "Simple application that displays onscreen Twitch chat",
  "main": "app.js",
  "type": "module",
  "engines": {
    "node": ">=22.x"
  },
  "scripts": {
    "start": "node dist/app.js",
    "auth": "node dist/utils/getOAuth.js",
    "build:server": "rimraf dist && tsc",
    "build:client": "rimraf public && node esbuild.config.js",
    "build": "npm run build:server && npm run build:client",
    "dev:server": "tsc-watch --onSuccess \"cross-env NODE_ENV=development node ./dist/app.js\"",
    "dev:client": "node esbuild.config.js --watch",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "keywords": [],
  "author": "iamconorwilson",
  "license": "ISC",
  "dependencies": {
    "express": "^5.2.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.2",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.0",
    "esbuild-copy-static-files": "^0.1.0",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "rimraf": "^6.1.2",
    "shx": "^0.4.0",
    "tsc-watch": "^7.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0"
  }
}